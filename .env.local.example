# ── Supabase Postgres ───────────────────────────────────────────────
# Pooled connection (Supavisor, port 6543) — used by the app at runtime on Vercel.
# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction" pooler.
# Append ?sslmode=require if not already present.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"

# Direct connection (port 5432) — used for migrations / index builds (no pgbouncer).
# Supabase Dashboard → Project Settings → Database → Connection string → "Direct connection".
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Anthropic (answer synthesis) ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Optional overrides
SYNTHESIS_MODEL="claude-3-5-haiku-latest"   # or claude-3-5-sonnet-latest for more depth
SYNTHESIS_MAX_TOKENS="1500"

# ── Embeddings (Anthropic has no embeddings API — pick a provider) ───
# Option A (fully OpenAI-free, Anthropic's recommended partner): Voyage AI.
#   Set VOYAGE_API_KEY; dimension auto = 1024.
# Option B: OpenAI embeddings only. Set OPENAI_API_KEY; dimension auto = 1536.
# EMBEDDINGS_PROVIDER is auto-detected (voyage if VOYAGE_API_KEY present, else openai).
# IMPORTANT: run `npm run migrate` AFTER choosing — the vector column dimension
# is set from the provider and changing providers later requires re-migrating.
VOYAGE_API_KEY=""
OPENAI_API_KEY=""
# Optional overrides
# EMBEDDINGS_PROVIDER="voyage"
# EMBEDDING_MODEL="voyage-3-large"
# EMBEDDING_DIM="1024"

# ── Stack Exchange / Stack Overflow (optional, raises API quota) ─────
# Register at https://stackapps.com/apps/oauth/register for a key.
STACKEXCHANGE_KEY=""
